# SalesEdge Git Attributes

# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python eol=lf
*.pyi text diff=python eol=lf
*.pyx text diff=python eol=lf

# TypeScript / JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Web
*.html text diff=html eol=lf
*.css text diff=css eol=lf
*.scss text diff=css eol=lf
*.svg text eol=lf

# Data / Config
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.env text eol=lf
*.csv text eol=lf

# Documentation
*.md text diff=markdown eol=lf
*.mdx text diff=markdown eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Docker
Dockerfile text eol=lf
Dockerfile.* text eol=lf
docker-compose*.yml text eol=lf
*.dockerignore text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
Makefile text eol=lf

# SQL
*.sql text eol=lf

# Protobuf
*.proto text eol=lf

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.svg text eol=lf

# Fonts (binary)
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Archives (binary)
*.zip binary
*.tar.gz binary
*.tgz binary
*.gz binary

# Lock files - don't diff
package-lock.json -diff
pnpm-lock.yaml -diff
uv.lock -diff

# Generated files - mark as generated (collapse in diffs)
frontend/src/types/api/generated.ts linguist-generated=true
docs/api/openapi.yaml linguist-generated=true

# Vendored dependencies
frontend/src/components/ui/** linguist-vendored=true

# Language statistics
*.css linguist-detectable=true
*.tsx linguist-language=TypeScript
