# SalesEdge Editor Configuration
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 120

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.{html,css,scss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

[Dockerfile*]
indent_size = 4
