# ─── SalesEdge environment (copy to .env and fill values) ───
# All variables use the SE_ prefix.

# ─── Core app ───
SE_ENVIRONMENT=development
SE_DEBUG=true
SE_LOG_LEVEL=INFO
SE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Database & cache ───
SE_DATABASE_URL=postgresql://salesedge:salesedge_dev@localhost:5432/salesedge
SE_REDIS_URL=redis://localhost:6379/0
# Used by docker-compose.prod.yml for PostgreSQL
SE_DB_PASSWORD=change_me_in_production

# ─── Auth ───
SE_JWT_SECRET_KEY=generate_a_long_random_secret

# ─── Open Government Data (data.gov.in) ───
SE_OGD_API_KEY=

# ─── Broker APIs ───
SE_DHAN_API_KEY=
SE_DHAN_CLIENT_ID=
SE_DHAN_ACCESS_TOKEN=

SE_ZERODHA_API_KEY=
SE_ZERODHA_API_SECRET=
SE_ZERODHA_ACCESS_TOKEN=

SE_UPSTOX_API_KEY=
SE_UPSTOX_API_SECRET=
SE_UPSTOX_ACCESS_TOKEN=

SE_ANGEL_API_KEY=
SE_ANGEL_CLIENT_CODE=
SE_ANGEL_PASSWORD=
SE_ANGEL_TOTP_SECRET=
SE_ANGEL_ACCESS_TOKEN=

SE_FYERS_API_KEY=
SE_FYERS_API_SECRET=
SE_FYERS_ACCESS_TOKEN=

SE_ICICI_API_KEY=
SE_ICICI_API_SECRET=
SE_ICICI_SESSION_TOKEN=

SE_DELTA_API_KEY=
SE_DELTA_API_SECRET=
SE_DELTA_ACCESS_TOKEN=

# ─── Market & enrichment APIs ───
SE_FINNHUB_API_KEY=
SE_TWELVE_DATA_API_KEY=
SE_ALPHA_VANTAGE_API_KEY=
SE_POLYGON_API_KEY=
SE_FMP_API_KEY=
SE_STOCKINSIGHTS_API_KEY=
SE_COINGECKO_API_KEY=

# ─── Foreign exchange ───
SE_OPEN_EXCHANGE_RATES_API_KEY=
SE_EXCHANGERATE_HOST_API_KEY=

# ─── CRM ───
SE_SALESFORCE_CLIENT_ID=
SE_SALESFORCE_CLIENT_SECRET=
SE_SALESFORCE_USERNAME=
SE_SALESFORCE_PASSWORD=
SE_SALESFORCE_SECURITY_TOKEN=
SE_SALESFORCE_INSTANCE_URL=

SE_HUBSPOT_API_KEY=
SE_HUBSPOT_CLIENT_ID=
SE_HUBSPOT_CLIENT_SECRET=
SE_HUBSPOT_ACCESS_TOKEN=

# ─── LLM / AI Provider ───
# Supports OpenRouter, OpenAI, Ollama (local), or any OpenAI-compatible API.
# OpenRouter (default, recommended — free tier models available):
#   Get a key at https://openrouter.ai/keys
# OpenAI:
#   Set SE_LLM_PROVIDER=openai  SE_LLM_BASE_URL=https://api.openai.com/v1
# Ollama (fully local, no API key needed):
#   Set SE_LLM_PROVIDER=ollama  SE_LLM_BASE_URL=http://localhost:11434/v1
SE_LLM_PROVIDER=openrouter
SE_LLM_API_KEY=
SE_LLM_BASE_URL=https://openrouter.ai/api/v1
SE_LLM_MODEL=google/gemini-2.0-flash-001
SE_LLM_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free
SE_LLM_MAX_TOKENS=4096
SE_LLM_TEMPERATURE=0.3
